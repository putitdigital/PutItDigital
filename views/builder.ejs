<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Put It Digital | Website Builder </title>
    <link rel="icon" type="image/x-icon" href="../photos/logo/favicon.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/builder.style.css">
        <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/feather-icons"></script>
</head>
<body class="bg-gray-50">
    <!-- Builder Layout -->
    <div class="builder-container">
        <!-- Sidebar -->
        <div class="bg-white p-4 shadow-sm">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold text-gray-800">Website Builder</h2>
                <button id="download-btn" class="bg-primary text-black px-4 py-2 rounded-md hover:bg-primary/90 transition">
                    <i class="fas fa-download mr-2"></i>Download
                </button>
            </div>

            <div class="mb-6">
                <div class="flex border-b border-gray-200">
                    <button class="tab-btn active-tab px-4 py-2 font-medium text-gray-700" data-tab="components">Components</button>
                    <button class="tab-btn px-4 py-2 font-medium text-gray-500" data-tab="settings">Settings</button>
                </div>
            </div>

            <div id="components-tab" class="tab-content">
                <div class="space-y-3">
                    <!-- Header -->
                    <div class="component-item bg-white p-4 rounded-lg border border-gray-200 cursor-move" draggable="true" data-type="header">
                        <div class="flex items-center">
                            <i class="fas fa-heading text-primary mr-3"></i>
                            <span class="font-medium">Header</span>
                        </div>
                    </div>
                    <div class="component-item bg-white p-4 rounded-lg border border-gray-200 cursor-move" draggable="true" data-type="hero">
                        <div class="flex items-center">
                            <i class="fas fa-star text-primary mr-3"></i>
                            <span class="font-medium">Hero Section</span>
                        </div>
                    </div>
                    <div class="component-item bg-white p-4 rounded-lg border border-gray-200 cursor-move" draggable="true" data-type="text">
                        <div class="flex items-center">
                            <i class="fas fa-text-width text-primary mr-3"></i>
                            <span class="font-medium">Text Block</span>
                        </div>
                    </div>
                    <div class="component-item bg-white p-4 rounded-lg border border-gray-200 cursor-move" draggable="true" data-type="features">
                        <div class="flex items-center">
                            <i class="fas fa-th-large text-primary mr-3"></i>
                            <span class="font-medium">Features</span>
                        </div>
                    </div>
                    <div class="component-item bg-white p-4 rounded-lg border border-gray-200 cursor-move" draggable="true" data-type="testimonials">
                        <div class="flex items-center">
                            <i class="fas fa-quote-right text-primary mr-3"></i>
                            <span class="font-medium">Testimonials</span>
                        </div>
                    </div>
                    <div class="component-item bg-white p-4 rounded-lg border border-gray-200 cursor-move" draggable="true" data-type="cta">
                        <div class="flex items-center">
                            <i class="fas fa-bullhorn text-primary mr-3"></i>
                            <span class="font-medium">Call to Action</span>
                        </div>
                    </div>
                </div>
            </div>

            <div id="settings-tab" class="tab-content hidden">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Page Title</label>
                        <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Primary Color</label>
                        <input type="color" value="#6366f1" class="w-full h-10">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Font</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded-md">
                            <option>Inter</option>
                            <option>Roboto</option>
                            <option>Open Sans</option>
                            <option>Montserrat</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Preview Area -->
        <div class="preview-container bg-gray-50 p-8">
            <div class="droppable-area bg-white rounded-lg p-6 mb-4">
                <p class="text-center text-gray-500">Drag and drop components here</p>
            </div>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="edit-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
    <div class="bg-white rounded-lg p-6 w-96">
        <h2 class="text-lg font-bold mb-4">Edit Component</h2>
        <div class="space-y-3">
        <label class="block font-medium text-gray-700">Text</label>
        <textarea id="edit-text" class="w-full p-2 border rounded-md"></textarea>

        <label class="block font-medium text-gray-700">Text Color</label>
        <input type="color" id="edit-text-color" class="w-full h-10">

        <label class="block font-medium text-gray-700">Background Color</label>
        <input type="color" id="edit-bg-color" class="w-full h-10">
        </div>

        <div class="mt-4 flex justify-end space-x-2">
        <button id="edit-cancel" class="px-4 py-2 rounded bg-gray-300 hover:bg-gray-400">Cancel</button>
        <button id="edit-save" class="px-4 py-2 rounded bg-blue-500 text-white hover:bg-blue-600">Save</button>
        </div>
    </div>
    </div>
    <!-- Header Edit Modal -->
    <div id="header-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
    <div class="bg-white rounded-lg p-6 w-96">

        <h2 class="text-lg font-bold mb-4">Edit Component</h2>
        <div class="space-y-3">
            <label class="block font-medium text-gray-700">Text</label>
            <textarea id="edit-text-header" class="w-full p-2 border rounded-md"> test</textarea>

            <label class="block font-medium text-gray-700">Text Color</label>
            <input type="color" id="edit-text-color-header" class="w-full h-10">

            <label class="block font-medium text-gray-700">Background Color</label>
            <input type="color" id="edit-bg-color-header" class="w-full h-10">
        </div>
        <h2 class="text-lg font-bold mb-4">Edit Header</h2>

        <div id="nav-items-container" class="space-y-2 max-h-60 overflow-y-auto">
        <!-- Nav items will be dynamically injected here -->
        </div>

        <button id="add-nav-item" class="mt-2 px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600">
        + Add Item
        </button>

        <div class="mt-4 flex justify-end space-x-2">
        <button id="header-cancel" class="px-4 py-2 rounded bg-gray-300 hover:bg-gray-400">Cancel</button>
        <button id="header-save" class="px-4 py-2 rounded bg-blue-500 text-white hover:bg-blue-600">Save</button>
        </div>
    </div>
    </div>


    <!-- Scripts -->
        <script src="./builder.main.js"></script>
</body>
</html>